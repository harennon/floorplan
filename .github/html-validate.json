{
  "extends": ["html-validate:recommended"],
  "rules": {
    "require-sri": "off",
    "no-trailing-whitespace": "off",
    "no-inline-style": "off",
    "prefer-native-element": "off",
    "prefer-button": "off",
    "script-type": "off",
    "no-raw-characters": "off",
    "attr-quotes": "off",
    "void-style": "off",
    "no-missing-references": "off",
    "long-title": "off",
    "wcag/h30": "off",
    "wcag/h32": "off",
    "wcag/h36": "off",
    "wcag/h37": "off",
    "wcag/h67": "off",
    "wcag/h71": "off"
  }
}
